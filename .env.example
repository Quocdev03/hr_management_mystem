# ============================================================
# File cấu hình môi trường - COPY file này thành .env rồi điền thông tin
# cp .env.example backend/.env
# ============================================================

# App
APP_PORT=8080
APP_ENV=development  # development | production

# Database (MySQL)
DB_HOST=localhost          # Nếu dùng Docker Compose: đổi thành "mysql"
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password123    # Đổi mật khẩu trong production!
DB_NAME=hrm_db

# JWT
JWT_SECRET=your-super-secret-key-min-32-chars-change-in-production
JWT_EXPIRE_HOUR=24
