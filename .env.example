# ==============================================================================
# HR Management System — Environment Variables Template
# ==============================================================================
# HƯỚNG DẪN:
# 1. Copy file này thành .env: cp .env.example .env
# 2. Điền các giá trị thực tế
# 3. KHÔNG commit .env vào Git
# 4. Trong production: dùng CI/CD secrets hoặc Docker Secrets
# ==============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 📱 APPLICATION
# ─────────────────────────────────────────────────────────────────────────────
# Giá trị: development | production
APP_ENV=development

# Port backend API
APP_PORT=8080

# Chạy seed dữ liệu mẫu khi khởi động (chỉ dùng cho development)
APP_SEED=true

# ─────────────────────────────────────────────────────────────────────────────
# 🗄️ DATABASE (MySQL)
# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose: DB_HOST=mysql | Local dev: DB_HOST=localhost
DB_HOST=localhost
DB_PORT=3306

# ⚠️ SECURITY: Không dùng root trong production!
DB_USER=hrm_user
DB_PASSWORD=change_me_strong_db_password

DB_NAME=hrm_db

# Password cho MySQL root user (dùng bởi Docker healthcheck)
MYSQL_ROOT_PASSWORD=change_me_strong_root_password

# ─────────────────────────────────────────────────────────────────────────────
# 🔐 JWT & AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────────
# ⚠️ PHẢI: ≥32 ký tự, random, mạnh
# Tạo bằng: openssl rand -base64 32
JWT_SECRET=change_me_min_32_chars_cryptographically_random_key
JWT_EXPIRE_HOUR=1
JWT_REFRESH_EXPIRE_DAY=7

# ─────────────────────────────────────────────────────────────────────────────
# 📦 REDIS
# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose: REDIS_HOST=redis | Local dev: REDIS_HOST=localhost
REDIS_HOST=localhost
REDIS_PORT=6379
# Development: để trống. Production: đặt password mạnh
REDIS_PASSWORD=
REDIS_DB=0

# ─────────────────────────────────────────────────────────────────────────────
# 🌐 CORS & SECURITY
# ─────────────────────────────────────────────────────────────────────────────
# Development: cho phép cả Vite dev port và Docker port
# Production: chỉ domain thật (ví dụ: https://hrm.company.com)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# 🖥️ FRONTEND (Vite)
# ─────────────────────────────────────────────────────────────────────────────
# Port Vite dev server
VITE_PORT=5173

# URL backend API — dùng khi chạy local không qua Docker proxy
# Development local: http://localhost:8080/api/v1
# Development Docker: /api/v1 (proxy qua nginx/vite)
VITE_API_URL=http://localhost:8080/api/v1

# ─────────────────────────────────────────────────────────────────────────────
# 💡 TẠO GIÁ TRỊ RANDOM
# ─────────────────────────────────────────────────────────────────────────────
# openssl rand -base64 32   → JWT_SECRET, MYSQL_ROOT_PASSWORD, DB_PASSWORD
# openssl rand -hex 16      → REDIS_PASSWORD
