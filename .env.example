# ==============================================================================
# HR Management System - Environment Variables Template
# ==============================================================================
# HƯỚNG DẪN:
# 1. Copy file này thành .env (sẽ được gitignore)
# 2. Điền các giá trị thực tế cho environment của bạn
# 3. KHÔNG commit .env vào Git
# 4. Trong production, dùng Docker Secrets hoặc environment variables từ CI/CD
# ==============================================================================

# ───────────────────────────────────────────────────────────────────────────
# 📱 APPLICATION CONFIG
# ───────────────────────────────────────────────────────────────────────────
APP_PORT=8080

# Giá trị: development | staging | production
APP_ENV=development

# Chạy seed dữ liệu mẫu khi khởi động (chỉ dùng cho dev/test)
APP_SEED=true

# ───────────────────────────────────────────────────────────────────────────
# 🗄️ DATABASE CONFIG (MySQL)
# ───────────────────────────────────────────────────────────────────────────
# Local: localhost | Docker Compose: mysql
DB_HOST=localhost
DB_PORT=3306

# ⚠️ SECURITY: KHÔNG dùng root trong production!
DB_USER=root
DB_PASSWORD=password123

DB_NAME=hrm_db

# ───────────────────────────────────────────────────────────────────────────
# 🔐 JWT & AUTHENTICATION
# ───────────────────────────────────────────────────────────────────────────
# ⚠️ PHẢI: ≥32 ký tự, random, mạnh
# Tạo bằng: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-min-32-chars-change-in-production
JWT_EXPIRE_HOUR=1
JWT_REFRESH_EXPIRE_DAY=7

# ───────────────────────────────────────────────────────────────────────────
# 📦 REDIS CONFIG
# ───────────────────────────────────────────────────────────────────────────
# Local: localhost | Docker Compose: redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ───────────────────────────────────────────────────────────────────────────
# 🌐 CORS & SECURITY
# ───────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ───────────────────────────────────────────────────────────────────────────
# 💡 TẠO GIÁ TRỊ RANDOM MẠNH
# ───────────────────────────────────────────────────────────────────────────
# openssl rand -base64 32

