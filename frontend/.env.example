# ==============================================================================
# HR Management System — Frontend Environment Variables Template
# ==============================================================================
# HƯỚNG DẪN:
# 1. Copy file này thành .env: cp .env.example .env
# 2. Điền giá trị phù hợp với môi trường của bạn
# 3. KHÔNG commit .env vào Git
# 4. Chỉ biến bắt đầu bằng VITE_ mới được expose ra client-side code
# ==============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 🌐 API
# ─────────────────────────────────────────────────────────────────────────────
# URL base cho backend API
# Local dev (không qua Docker): http://localhost:8080/api/v1
# Docker dev (qua Vite proxy):   /api/v1
VITE_API_URL=http://localhost:8080/api/v1

# ─────────────────────────────────────────────────────────────────────────────
# 🖥️ DEV SERVER
# ─────────────────────────────────────────────────────────────────────────────
# Port Vite dev server (chỉ dùng khi chạy trong Docker Compose)
VITE_PORT=5173
